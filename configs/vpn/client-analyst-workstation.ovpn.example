# OpenVPN Client Configuration — analyst-workstation  [TEMPLATE / EXAMPLE]
# ---------------------------------------------------------------------------
# This is a SANITIZED TEMPLATE, not a working profile. All certificate/key
# material is redacted. A real .ovpn profile contains private keys and must
# NEVER be committed to a repository. Export the real bundle from:
#   pfSense > VPN > OpenVPN > Client Export
# ---------------------------------------------------------------------------
# Profile: analyst-workstation | Issued: 2026-02-01 | Expires: 2027-02-01
# Author: Ari Said
#
# USAGE (with a real exported profile):
#   Linux/macOS:  sudo openvpn --config analyst-workstation.ovpn
#   Windows:      Import into OpenVPN GUI or OpenVPN Connect
#   Mobile:       Import into OpenVPN Connect app

client
dev tun
proto udp4

# Remote server — WAN IP or DDNS hostname
remote [WAN_IP_OR_DDNS_HOSTNAME] 1194

# Fallback: TCP 443 if UDP 1194 is blocked (restrictive networks, hotels).
# Uncomment to enable:
# remote [WAN_IP_OR_DDNS_HOSTNAME] 443 tcp

# ── Cryptography ─────────────────────────────────────────────────────────────
# Data channel cipher negotiation (OpenVPN 2.5+). Must match server.
data-ciphers AES-256-GCM:AES-128-GCM
data-ciphers-fallback AES-256-GCM

# Control-channel HMAC digest (used by tls-crypt below)
auth SHA256

tls-version-min 1.3
tls-client

# Verify server certificate CN matches expected value (prevents MITM)
verify-x509-name vpn.lab.internal name

# ── Control Channel Protection ────────────────────────────────────────────────
# tls-crypt supersedes tls-auth — encrypts and authenticates the control
# channel. The key below is shared with the server and is a SECRET.
<tls-crypt>
[REDACTED — tls-crypt key. Export from pfSense Client Export. Never commit.]
</tls-crypt>

# ── Certificates ─────────────────────────────────────────────────────────────
<ca>
[REDACTED — Lab-Internal-CA certificate]
</ca>

<cert>
[REDACTED — analyst-workstation client certificate]
</cert>

<key>
[REDACTED — analyst-workstation private key — NEVER commit a real key]
</key>

# ── Connection Behavior ───────────────────────────────────────────────────────
# Retry indefinitely on connection failure
resolv-retry infinite

# Don't bind to a specific local port
nobind

# Persist key/tun across restarts
persist-key
persist-tun

# Use server-pushed routes (split tunnel). pfSense pushes routes for lab
# VLANs only; internet traffic goes out the local default gateway.
pull

# Block DNS outside the tunnel (Windows DNS-leak prevention). Also pushed
# by the server; set here as client-side defense in depth.
block-outside-dns

# ── Logging ──────────────────────────────────────────────────────────────────
verb 3

# ── Post-Connection Validation ────────────────────────────────────────────────
# After connecting, verify the following manually:
#
# 1. Routing table shows lab subnets via the tun interface:
#    Linux/macOS:  ip route | grep tun
#    Windows:      route print | findstr 192.168
#
# 2. DNS resolves internal hostnames:
#    nslookup wazuh.lab.internal      → expected: 10.0.40.50
#
# 3. No DNS leak:
#    Visit https://dnsleaktest.com    → expected: pfSense's ISP, not home ISP
#
# 4. pfSense GUI reachable over the tunnel:
#    https://10.0.99.1   (Management VLAN — VPN clients permitted)
